generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            String         @id @default(cuid())
  name          String
  sku           String         @unique
  image         String?
  currentStock  Int            @default(0)
  basePrice     Float          @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  inventoryLogs InventoryLog[]
  orderItems    OrderItem[]

  @@map("products")
}

model ImportReceipt {
  id            String         @id @default(cuid())
  code          String         @unique
  providerId    String?
  totalAmount   Float          @default(0)
  creatorId     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  creator       User           @relation(fields: [creatorId], references: [id])
  supplier      Supplier?      @relation(fields: [providerId], references: [id])
  inventoryLogs InventoryLog[]

  @@map("import_receipts")
}

model InventoryLog {
  id          String         @id @default(cuid())
  productId   String
  quantity    Int
  importPrice Float
  createdAt   DateTime       @default(now())
  providerId  String?
  receiptId   String?
  product     Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier    Supplier?      @relation(fields: [providerId], references: [id])
  receipt     ImportReceipt? @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([providerId])
  @@index([receiptId])
  @@map("inventory_logs")
}

model Order {
  id            String        @id @default(cuid())
  code          String        @unique
  customerName  String?
  customerId    String?
  totalAmount   Float         @default(0)
  discountType  DiscountType?
  discountValue Float?        @default(0)
  finalAmount   Float         @default(0)
  paymentStatus PaymentStatus @default(PAID)
  paymentMethod PaymentMethod @default(CASH)
  transactionId String?
  paymentImage  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Snapshot information for the order
  customerPhone   String?
  customerAddress String?
  taxCode         String?
  customerType    CustomerType @default(INDIVIDUAL)

  // Quan hệ
  items    OrderItem[]
  customer Customer?   @relation(fields: [customerId], references: [id])

  @@map("orders")
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String
  quantity       Int
  priceAtSale    Float
  discountAtSale Float?  @default(0)
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  password       String
  role           Role            @default(ADMIN)
  image          String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  importReceipts ImportReceipt[]

  @@map("users")
}

model Customer {
  id            String        @id @default(cuid())
  name          String
  phone         String        @unique
  email         String?
  address       String?
  taxCode       String?
  type          CustomerType  @default(INDIVIDUAL)
  grade         CustomerGrade @default(NORMAL)
  totalSpending Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  orders Order[]

  @@map("customers")
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  contactName    String?
  phone          String?
  email          String?
  taxCode        String?
  address        String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  importReceipts ImportReceipt[]
  inventoryLogs  InventoryLog[]

  @@map("suppliers")
}

enum CustomerGrade {
  NORMAL
  VIP
}

enum DiscountType {
  PERCENT
  FIXED
}

enum PaymentStatus {
  PAID
  PENDING
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

enum CustomerType {
  INDIVIDUAL
  COMPANY
}
